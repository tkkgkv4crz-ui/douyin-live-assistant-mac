{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["electron-vite/node"]
  },
  "include": ["electron/**/*.ts", "src/**/*.ts", "src/**/*.d.ts", "*.config.ts"]
}
